#!/usr/bin/env bash
# morning-brief — consolidated tail of every autonomous rig's morning-log.
#
# Walks --root (default ~/dev/projects), finds every
# ops/autonomous/morning-log.md, prints a per-project digest.
#
# No parser: treats each log as text, pulls date-prefixed lines when
# present, falls back to raw tail when not.

set -u

VERSION="0.1.0"

root="${HOME}/dev/projects"
tail_n=8
since=""
today_only=0

usage() {
  cat <<EOF
morning-brief ${VERSION}

Usage: morning-brief [--today] [--since YYYY-MM-DD] [-n N] [--root PATH]

  --today          only lines dated today
  --since DATE     only lines dated on or after DATE (YYYY-MM-DD)
  -n N             tail last N matching lines per project (default 8)
  --root PATH      workspace root to scan (default \$HOME/dev/projects)
  -h, --help       show this help
  -V, --version    print version
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --today)      today_only=1; shift ;;
    --since)      since="${2:-}"; shift 2 ;;
    -n)           tail_n="${2:-}"; shift 2 ;;
    --root)       root="${2:-}"; shift 2 ;;
    -h|--help)    usage; exit 0 ;;
    -V|--version) echo "$VERSION"; exit 0 ;;
    *) echo "morning-brief: unknown arg: $1" >&2; usage >&2; exit 2 ;;
  esac
done

if [[ "$today_only" -eq 1 ]]; then
  since="$(date +%F)"
fi

if [[ -n "$since" ]]; then
  if ! [[ "$since" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    echo "morning-brief: --since/--today requires YYYY-MM-DD, got: $since" >&2
    exit 2
  fi
fi

if [[ ! -d "$root" ]]; then
  echo "morning-brief: root not found: $root" >&2
  exit 2
fi

# ANSI — respect NO_COLOR and non-tty.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'
else
  BOLD=""; DIM=""; RESET=""
fi

# Project label = first path segment under $root. Handles nested
# logs like claude-expo/ichnograph/ops/autonomous/morning-log.md by
# joining with "/" so both layers are visible.
project_label() {
  local log="$1" rel
  rel="${log#"$root"/}"
  # strip the trailing /ops/autonomous/morning-log.md
  rel="${rel%/ops/autonomous/morning-log.md}"
  printf '%s' "$rel"
}

# Filter a log's lines for display.
#
#   No --since   → raw tail of the last N non-blank lines.
#                  Robust across every log format (date-prefixed,
#                  time-prefixed, bulleted, headered).
#
#   --since set  → only lines containing an ISO date >= $since,
#                  tailed to N. ISO dates are lex-sortable, so
#                  string compare is correct.
filter_log() {
  local log="$1"
  if [[ -z "$since" ]]; then
    grep -v '^[[:space:]]*$' -- "$log" | tail -n "$tail_n"
    return
  fi
  awk -v since="$since" '
    match($0, /2[0-9]{3}-[0-9]{2}-[0-9]{2}/) {
      d = substr($0, RSTART, RLENGTH)
      if (d >= since) print $0
    }
  ' "$log" | tail -n "$tail_n"
}

# Horizontal rule that fits the terminal (or 64 cols off-tty).
rule() {
  local label="$1" cols=64
  if [[ -t 1 ]]; then
    cols="$(tput cols 2>/dev/null || echo 64)"
  fi
  local prefix="── ${label} "
  local pad=$(( cols - ${#prefix} ))
  (( pad < 3 )) && pad=3
  printf '%s%s' "$BOLD" "$prefix"
  printf '─%.0s' $(seq 1 "$pad")
  printf '%s\n' "$RESET"
}

# Discover logs. Sorted for deterministic output.
mapfile -t logs < <(
  find "$root" -maxdepth 5 -type f -path '*/ops/autonomous/morning-log.md' 2>/dev/null | sort
)

if [[ ${#logs[@]} -eq 0 ]]; then
  echo "morning-brief: no morning-log.md found under $root" >&2
  exit 1
fi

header_context=""
if [[ -n "$since" ]]; then
  if [[ "$today_only" -eq 1 ]]; then
    header_context=" (today: $since)"
  else
    header_context=" (since $since)"
  fi
fi

printf '%smorning-brief%s%s — %d log(s) under %s\n\n' \
  "$BOLD" "$RESET" "$header_context" "${#logs[@]}" "$root"

for log in "${logs[@]}"; do
  label="$(project_label "$log")"
  rule "$label"
  out="$(filter_log "$log")"
  if [[ -z "$out" ]]; then
    printf '  %s(no matching entries)%s\n' "$DIM" "$RESET"
  else
    # Indent two spaces for readability; preserve blank lines.
    sed 's/^/  /' <<<"$out"
  fi
  printf '\n'
done
