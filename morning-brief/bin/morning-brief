#!/usr/bin/env bash
# morning-brief — consolidated tail of every autonomous rig's morning-log.
#
# Walks --root (default ~/dev/projects), finds every
# ops/autonomous/morning-log.md, prints a per-project digest.
#
# No parser: treats each log as text, pulls date-prefixed lines when
# present, falls back to raw tail when not.

set -u

VERSION="0.5.0"

root="${HOME}/dev/projects"
tail_n=8
since=""
today_only=0
projects_filter=""
show_git=1

usage() {
  cat <<EOF
morning-brief ${VERSION}

Usage: morning-brief [--today] [--since YYYY-MM-DD] [-n N]
                     [--projects LIST] [--root PATH]

  --today          only lines dated today
  --since DATE     only lines dated on or after DATE (YYYY-MM-DD)
  -n N             tail last N matching lines per project (default 8)
  --projects LIST  comma-separated substrings; show only matching
                   project labels (case-insensitive)
  --root PATH      workspace root to scan (default \$HOME/dev/projects)
  --no-git         skip the per-project git summary line
  -h, --help       show this help
  -V, --version    print version
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --today)      today_only=1; shift ;;
    --since)      since="${2:-}"; shift 2 ;;
    -n)           tail_n="${2:-}"; shift 2 ;;
    --projects)   projects_filter="${2:-}"; shift 2 ;;
    --root)       root="${2:-}"; shift 2 ;;
    --no-git)     show_git=0; shift ;;
    -h|--help)    usage; exit 0 ;;
    -V|--version) echo "$VERSION"; exit 0 ;;
    *) echo "morning-brief: unknown arg: $1" >&2; usage >&2; exit 2 ;;
  esac
done

if [[ "$today_only" -eq 1 ]]; then
  since="$(date +%F)"
fi

if [[ -n "$since" ]]; then
  if ! [[ "$since" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    echo "morning-brief: --since/--today requires YYYY-MM-DD, got: $since" >&2
    exit 2
  fi
fi

if [[ ! -d "$root" ]]; then
  echo "morning-brief: root not found: $root" >&2
  exit 2
fi

# ANSI — respect NO_COLOR and non-tty.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'
  RED=$'\033[31m'; YELLOW=$'\033[33m'; GREEN=$'\033[32m'; CYAN=$'\033[36m'
  RESET=$'\033[0m'
else
  BOLD=""; DIM="";
  RED=""; YELLOW=""; GREEN=""; CYAN=""
  RESET=""
fi

# Project label = first path segment under $root. Handles nested
# logs like claude-expo/ichnograph/ops/autonomous/morning-log.md by
# joining with "/" so both layers are visible.
project_label() {
  local log="$1" rel
  rel="${log#"$root"/}"
  # strip the trailing /ops/autonomous/morning-log.md
  rel="${rel%/ops/autonomous/morning-log.md}"
  printf '%s' "$rel"
}

# Filter a log's lines for display.
#
#   No --since   → raw tail of the last N non-blank lines.
#                  Robust across every log format (date-prefixed,
#                  time-prefixed, bulleted, headered).
#
#   --since set  → only lines containing an ISO date >= $since,
#                  tailed to N. ISO dates are lex-sortable, so
#                  string compare is correct.
filter_log() {
  local log="$1"
  if [[ -z "$since" ]]; then
    grep -v '^[[:space:]]*$' -- "$log" | tail -n "$tail_n"
    return
  fi
  awk -v since="$since" '
    match($0, /2[0-9]{3}-[0-9]{2}-[0-9]{2}/) {
      d = substr($0, RSTART, RLENGTH)
      if (d >= since) print $0
    }
  ' "$log" | tail -n "$tail_n"
}

# Horizontal rule that fits the terminal (or 64 cols off-tty).
rule() {
  local label="$1" cols=64
  if [[ -t 1 ]]; then
    cols="$(tput cols 2>/dev/null || echo 64)"
  fi
  local prefix="── ${label} "
  local pad=$(( cols - ${#prefix} ))
  (( pad < 3 )) && pad=3
  printf '%s%s' "$BOLD" "$prefix"
  printf '─%.0s' $(seq 1 "$pad")
  printf '%s\n' "$RESET"
}

# Git one-liner for a project: short HEAD sha, commit-count in the
# active window, dirty-tree marker, and the HEAD subject. "Active
# window" is --since when set (so the cadence line agrees with the
# tail filter); else the last 24 hours, which is the morning-review
# default.
#
# Silent if the directory is not inside a git repo, if git isn't
# installed, or if --no-git was passed. Emits "(no commits)" for an
# empty repo.
#
# The dirty-tree segment is the answer to "why does this rig keep
# logging skipped?" — a wall of skips with a clean HEAD line is a
# stuck timer; a wall of skips with `dirty: 18` is a tree the rig
# can't safely act on.
#
# Arg: absolute path to the project dir (the dir containing the log).
git_summary() {
  local dir="$1"
  [[ "$show_git" -eq 1 ]] || return 0
  command -v git >/dev/null 2>&1 || return 0
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0

  local sha subject count window_label dirty dirty_seg=""
  local unpushed unpushed_seg=""
  if ! sha="$(git -C "$dir" rev-parse --short HEAD 2>/dev/null)"; then
    printf '%sHEAD —%s  %s(no commits)%s\n' "$DIM" "$RESET" "$DIM" "$RESET"
    return 0
  fi
  subject="$(git -C "$dir" log -1 --format=%s HEAD 2>/dev/null)"

  if [[ -n "$since" ]]; then
    window_label="since $since"
    count="$(git -C "$dir" rev-list --count --since="$since 00:00:00" HEAD 2>/dev/null)"
  else
    window_label="last 24h"
    count="$(git -C "$dir" rev-list --count --since="24 hours ago" HEAD 2>/dev/null)"
  fi
  count="${count:-0}"
  local plural=s
  [[ "$count" == "1" ]] && plural=""

  # Unpushed: HEAD ahead of upstream. Silently skipped when there is
  # no upstream configured (lib/, fresh repo, detached HEAD) — that's
  # a different shape of "not pushed" and not the one this segment is
  # trying to surface. The signal here is "the rig committed but the
  # remote hasn't seen it yet" — a `dev` ahead of `origin/dev` story
  # that the morning brief was previously blind to.
  if git -C "$dir" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    unpushed="$(git -C "$dir" rev-list --count '@{u}..HEAD' 2>/dev/null)"
    if [[ "${unpushed:-0}" -gt 0 ]]; then
      unpushed_seg=" · ${CYAN}unpushed: ${unpushed}${RESET}${DIM}"
    fi
  fi

  dirty="$(git -C "$dir" status --porcelain 2>/dev/null | wc -l)"
  if [[ "${dirty:-0}" -gt 0 ]]; then
    dirty_seg=" · ${YELLOW}dirty: ${dirty}${RESET}${DIM}"
  fi

  printf '%sHEAD %s%s  %s· %s commit%s %s%s%s · %s%s\n' \
    "$DIM" "$sha" "$RESET" \
    "$DIM" "$count" "$plural" "$window_label" "$unpushed_seg" "$dirty_seg" "$subject" "$RESET"
}

# Returns 0 if $1 matches the --projects filter (or if no filter set).
matches_projects() {
  [[ -z "$projects_filter" ]] && return 0
  local label_lc="${1,,}" needle needle_lc
  local IFS=','
  for needle in $projects_filter; do
    needle_lc="${needle,,}"
    [[ -z "$needle_lc" ]] && continue
    if [[ "$label_lc" == *"$needle_lc"* ]]; then
      return 0
    fi
  done
  return 1
}

# Discover logs. Sorted for deterministic output.
mapfile -t all_logs < <(
  find "$root" -maxdepth 5 -type f -path '*/ops/autonomous/morning-log.md' 2>/dev/null | sort
)

logs=()
for log in "${all_logs[@]}"; do
  if matches_projects "$(project_label "$log")"; then
    logs+=("$log")
  fi
done

if [[ ${#all_logs[@]} -eq 0 ]]; then
  echo "morning-brief: no morning-log.md found under $root" >&2
  exit 1
fi

if [[ ${#logs[@]} -eq 0 ]]; then
  echo "morning-brief: --projects filter matched 0 of ${#all_logs[@]} logs" >&2
  exit 1
fi

header_context=""
if [[ -n "$since" ]]; then
  if [[ "$today_only" -eq 1 ]]; then
    header_context=" (today: $since)"
  else
    header_context=" (since $since)"
  fi
fi

# Today-active count: how many logs have at least one line dated
# today. Answers "which rigs ran overnight?" at a glance, regardless
# of --since / --today / --projects filtering — so you still see a
# silent rig even when drilling into a specific one.
today="$(date +%F)"
active_today=0
silent_today=()
for log in "${all_logs[@]}"; do
  if grep -q -F "$today" -- "$log"; then
    active_today=$(( active_today + 1 ))
  else
    silent_today+=("$(project_label "$log")")
  fi
done

# Dirty-tree and unpushed counts across all_logs (not just the
# filtered set) — same rationale as silent_today: a --projects
# drill-down should not hide a dirty tree or an unpushed branch
# elsewhere in the workspace. Both pass through a single git walk so
# we don't shell out twice per project.
dirty_total=0
dirty_projects=()
unpushed_total=0
unpushed_projects=()
if [[ "$show_git" -eq 1 ]] && command -v git >/dev/null 2>&1; then
  for log in "${all_logs[@]}"; do
    project_dir="${log%/ops/autonomous/morning-log.md}"
    git -C "$project_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || continue

    n="$(git -C "$project_dir" status --porcelain 2>/dev/null | wc -l)"
    if [[ "${n:-0}" -gt 0 ]]; then
      dirty_total=$(( dirty_total + 1 ))
      dirty_projects+=("$(project_label "$log")")
    fi

    if git -C "$project_dir" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
      ahead="$(git -C "$project_dir" rev-list --count '@{u}..HEAD' 2>/dev/null)"
      if [[ "${ahead:-0}" -gt 0 ]]; then
        unpushed_total=$(( unpushed_total + 1 ))
        unpushed_projects+=("$(project_label "$log")")
      fi
    fi
  done
fi

printf '%smorning-brief%s%s — %d log(s) under %s\n' \
  "$BOLD" "$RESET" "$header_context" "${#logs[@]}" "$root"
printf '  %sactive today: %d%s  ·  %ssilent today: %d%s' \
  "$BOLD" "$active_today" "$RESET" \
  "$DIM" "${#silent_today[@]}" "$RESET"
if (( ${#silent_today[@]} > 0 )); then
  printf ' %s(%s)%s' "$DIM" "$(IFS=,; echo "${silent_today[*]}")" "$RESET"
fi
if [[ "$show_git" -eq 1 ]]; then
  if (( unpushed_total > 0 )); then
    printf '  ·  %sunpushed: %d%s' "$CYAN" "$unpushed_total" "$RESET"
    printf ' %s(%s)%s' "$DIM" "$(IFS=,; echo "${unpushed_projects[*]}")" "$RESET"
  else
    printf '  ·  %sunpushed: 0%s' "$DIM" "$RESET"
  fi
  if (( dirty_total > 0 )); then
    printf '  ·  %sdirty trees: %d%s' "$YELLOW" "$dirty_total" "$RESET"
    printf ' %s(%s)%s' "$DIM" "$(IFS=,; echo "${dirty_projects[*]}")" "$RESET"
  else
    printf '  ·  %sdirty trees: 0%s' "$DIM" "$RESET"
  fi
fi
printf '\n\n'

# Colorize status words in-place. Tail lines are raw log text, so a
# light sed dusting is enough — we're not parsing structure, just
# making the "something's stuck" / "something shipped" signals
# visible at a glance when scrolling the morning brief.
#
# Tuned for the vocabulary actually seen in the workspace's logs:
#   - skipped  → yellow (idle / gated / waiting-for-human)
#   - pushed   → green  (a commit landed on dev)
#   - error / FAIL / WARN → red (something went sideways)
#
# No ANSI when colors are off, so this is a no-op on pipes.
highlight_status() {
  if [[ -z "$RESET" ]]; then
    cat
    return
  fi
  sed -E \
    -e "s/\b(skipped|SKIPPED)\b/${YELLOW}\1${RESET}/g" \
    -e "s/\b(pushed|PUSHED)\b/${GREEN}\1${RESET}/g" \
    -e "s/\b(error|ERROR|FAIL|FAILED|WARN|WARNING)\b/${RED}\1${RESET}/g"
}

for log in "${logs[@]}"; do
  label="$(project_label "$log")"
  rule "$label"
  project_dir="${log%/ops/autonomous/morning-log.md}"
  git_line="$(git_summary "$project_dir")"
  if [[ -n "$git_line" ]]; then
    printf '  %s\n' "$git_line"
  fi
  out="$(filter_log "$log")"
  if [[ -z "$out" ]]; then
    printf '  %s(no matching entries)%s\n' "$DIM" "$RESET"
  else
    sed 's/^/  /' <<<"$out" | highlight_status
  fi
  printf '\n'
done
